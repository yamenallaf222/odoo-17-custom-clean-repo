{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Odoo Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/odoo-bin",
            "consoleName": "Odoo Python Debug Console",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/venv/Scripts/python",
            "args": [
                "-c",
                "odoo.conf",
                "-u",
                "todo_app",
                "-d",
                "todo_app",
                "--dev=all"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        }
    ]
}