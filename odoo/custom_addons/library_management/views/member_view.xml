<odoo>
    <record id="member_kanban_view" model="ir.ui.view">
        <field name="name">member.kanban.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" >
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12 mb-1 d-flex justify-content-center">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="mt-1">
                                    <div>
                                        <strong>Member E-mail: </strong>
                                        <t t-esc="record.partner_id and record.partner_id.email ? record.partner_id.email.raw_value : 'None'"/>
                                    </div>

                                    <div>
                                        <strong>Member phone: </strong>
                                        <t t-esc="record.partner_id and record.partner_id.phone ? record.partner_id.phone.raw_value : 'None'"/>
                                    </div>
                                </div>

                                <div class="mt-1">
                                    <strong>Membership: </strong>
                                    <t t-esc="record.membership_type and record.membership_type.name ? record.membership_type.name.raw_value : 'None'"/>
                                </div>
                            </div>  
                        </div> 
                    </t>
                </templates>
            </kanban>   
        </field>
    </record>

    <record id="member_view_tree" model="ir.ui.view">
        <field name="name">Book tree</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="membership_type"/>
            </tree>
        </field>
    </record>

    <record id="member_view_form" model="ir.ui.view">
        <field name="name">Member form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <group col="3">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="membership_type"/>  
                </group>
            </form>
        </field>
    </record>

    <record id="member_view_action" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem 
        id="members_menu_item"
        name="Members"
        parent="members_menu"
        action="member_view_action"
    />
</odoo>