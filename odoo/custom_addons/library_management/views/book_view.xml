<odoo>
    <record id="book_kanban_view" model="ir.ui.view">
        <field name="name">book.kanban.view</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" >
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12 mb-1 d-flex justify-content-center">
                                    <strong>
                                        <field name="title"/>
                                    </strong>
                                </div>
                            </div>
                            
                            <div> 

                                <div>
                                    <strong>Author: </strong> <field name="author"/>.
                                </div>

                                <div>
                                    <strong>Category: </strong> <t t-esc="record.category ? record.category.name : 'None' + '.'"/>
                                </div>

                                <div>
                                    <strong>Date added: </strong> <field name="acquisition_date"/>
                                </div>
                                
                            </div>

                            <div t-att-class="'book_availability_pill ' + (record.availability_status.raw_value)">
                                <field name="availability_status"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>   
        </field>
    </record>

    <record id="book_view_tree" model="ir.ui.view">
        <field name="name">Book tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <tree>
                <field name="title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="category"/>
                <field name="active" invisible="True"/>
                <field name="depreciation" invisible="True"/>
                <field name="depreciation_rate" invisible="True"/>
                <field name="availability_status" readonly="True"/>
                <field name="acquisition_date"/>
            </tree>
        </field>
    </record>

    <record id="book_view_form" model="ir.ui.view">
        <field name="name">Book form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <group col="2">
                    <group string="Basic info.">
                        <field name="title" placeholder="Title"/>
                        <field name="author" placeholder="Author"/>
                        <field name="category" placeholder="Category"/>
                    </group>

                    <group string="Advanced info.">
                        <field name="isbn" string="ISBN"/>
                        <field name="active" invisible="True"/>
                        <field name="depreciation" invisible="True"/>
                        <field name="depreciation_rate" invisible="True"/>
                        <field name="availability_status" readonly="True"/>
                        <field name="acquisition_date"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <record id="book_view_action" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem 
        id="books_menu_item"
        name="Books"
        parent="books_menu"
        action="book_view_action"
    />
</odoo>