<templates xml:space="preserve">
    <t t-name="todo_app.TodoTimerWidget">
        <div class="todo-timer-widget p-3 border rounded">
            
            <div class="mb-3">
                <strong>Elapsed: <span t-esc="(state.elapsed || 0).toFixed(2)"> hours </span> </strong>
            </div>

            <div t-attf-class=" mb-3 text-muted + (state.running ? 'text-success' : 'text-danger')">
                <t t-if="state.running">
                    <span>Running since: </span> <span t-esc="state.start_time || 'Just started'"/>
                </t>

                <t t-else="">
                    <span>Stopped: </span> <span t-esc="state.stop_time || 'Never'"/>
                </t>
            </div>

            <div class="btn-group w-100" role="group">
                <button t-on-click="startTimer" t-att-disabled="state.running" class="btn btn-success flex-fill">
                    <i class="fa fa-play"/> Start Timer

                </button>

                <button t-on-click="stopTimer" t-att-disabled="!state.running" class="btn btn-danger flex-fill">
                    <i class="fa fa-stop"/> Stop Timer
                </button>

            </div>
        </div>
    </t>
</templates>