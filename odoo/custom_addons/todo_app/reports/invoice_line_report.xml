<odoo>
    <record id="invoice_line_report" model="ir.actions.report">
        <field name="name">Invoice Report</field>
        <field name="model">invoice.line</field>
        <field name="report_type">qweb-html</field>
        <field name="binding_model_id" ref="model_invoice_line"/>
        <field name="binding_type">report</field>
        <field name="report_name">todo_app.invoice_report_template</field>
    </record>

    <template id="invoice_report_template">
        <t t-call="web.html_container">
            <div style= "padding: 10px; margin: 25%;">
                <t t-call="web.external_layout">
                    <hr/>
                    <t t-foreach="docs" t-as="o">
                        <div style="border: 1px solid black; padding: 5%;">
                            <span style="font-size:20px;"><strong>Invoice:</strong>&#160;&#160;&#160;&#160;&#160;<span t-field="o.name"/></span>
                            <br/>
                            <div style="margin-left: 2em;">

                                <span style="font-size=20px;"><strong>N.O:</strong>&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<span t-field="o.ref"/></span>
                                <br/>
                                <span style="font-size=20px;"><strong>Billed to:</strong>&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<span t-field="o.client_id"/></span>
                                <br/>
                                <span style="font-size=20px;"><strong>Issue date:</strong>&#160;&#160;&#160;&#160;<span t-field="o.invoice_date"/></span>
                                <br/>
                                <br/>
                                <span style="font-size=20px;"><strong>Total hours:</strong>&#160;&#160;&#160;&#160;<span t-field="o.total_hours"/></span>
                                <br/>
                                <span style="font-size=20px;"><strong>Total amount:</strong>&#160;&#160;&#160;&#160;<span t-field="o.total_amount"/></span>
                                <br/>
                                <br/>


                            </div>
                            <!-- <br/>
                            <span style="font-size=20px;"><strong>Description:</strong></span>
                            <br/>
                            <span style="overflow-wrap: break-word;"><span t-field="o.description"/>.</span>
                            <br/>
                            <br/> -->
                            <style>
                                table {
                                width:100%;
                                border:1px solid #b3adad;
                                border-collapse:collapse;
                                padding:5px;
                                }

                                table th {
                                border:1px solid #b3adad;
                                padding:5px;
                                background: #f0f0f0;
                                color: #313030;
                                }

                                table td {
                                border:1px solid #b3adad;
                                text-align:center;
                                padding:5px;
                                background: #ffffff;
                                color: #313030;
                                }

                            </style>
                            <table>
                                <thead>
                                    <th style="text-align: center;" colspan="6">Tasks</th>
                                </thead>
                                <thead style="text-align: center;">
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Subtasks</th>
                                    <th>Time</th>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.task_ids" t-as="task">
                                        <tr>
                                            <td><t t-esc="task.id"/></td>
                                            <td><t t-esc="task.name"/></td>
                                            <td><t t-esc="task.due_date"/></td>
                                            <td><t t-esc="task.description"/></td>                                            
                                            <td>
                                                <t t-foreach="task.timesheet_line_ids" t-as="subtask">
                                                    <span><t t-esc="subtask.description"/>,  </span>
                                                </t>
                                            </td>
                                            <td><span><t t-esc="task.estimated_time"/></span></td>
                                        </tr>
                                    </t>
                                </tbody>

                                <!-- <tr>
                                    <td colspan="3">Total Time</td>
                                    <td><span><t t-esc="o.timesheet_lines_total_time"/> H</span></td>
                                </tr> -->
                            </table>
                        </div>
                    </t>
                </t>
            </div>
        </t>
    </template>
</odoo>