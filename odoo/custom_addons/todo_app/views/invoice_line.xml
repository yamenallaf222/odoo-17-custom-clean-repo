<odoo>
    <record id="invoice_line_view_tree" model="ir.ui.view">
        <field name="name">invoice line tree</field>
        <field name="model">invoice.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="task_ids"/>
                <field name="client_id"/>
                <field name="total_hours"/>
                <field name="total_amount"/>
                <field name="currency_id" optional="1"/>
                <field name="invoice_date"/>
            </tree>
        </field>
    </record>
    
    <record id="invoice_line_view_form" model="ir.ui.view">
        <field name="name">invoice line form</field>
        <field name="model">invoice.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>

                        <label for="name"/>
                        <h3>
                            <field name="name"/>
                        </h3>

                    </div>


                    <group>
                        <!-- even though this is a one2many field, this widget attribute is necessary to make it a selection not a creation of tasks -->
                        <field name="task_ids" widget="many2many"/>
                        <field name="client_id" />
                        <field name="total_hours" />
                        <field name="total_amount" widget="monetary"/>
                        <field name="currency_id"/>
                        <field name="invoice_date" />
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
            
        </field>
    </record>

    <record id="invoice_line_action" model="ir.actions.act_window">
        <field name="name">Invoice Line</field>
        <field name="res_model">invoice.line</field>
    </record>

    
    <menuitem 
        id="invoice_line_menu"
        name="Invoice Line"
        parent="to_do_menu"
        action="invoice_line_action"
    />
</odoo>